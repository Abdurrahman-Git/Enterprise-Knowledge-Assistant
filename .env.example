# ─── Google Gemini ───────────────────────────────────────────────────────────
# Free key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# LLM for answering questions
LLM_MODEL=gemini-1.5-flash

# Embedding model (converts text to vectors)
# text-embedding-004 is Google's best free embedding model
EMBEDDING_MODEL=models/text-embedding-004

# ─── Vector Database ──────────────────────────────────────────────────────────
# ChromaDB stores its data in this local folder
CHROMA_PERSIST_DIR=./chroma_db

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_NAME=Enterprise Knowledge Assistant
DEBUG=true

# How many document chunks to retrieve per question
# Higher = more context but slower and more tokens
TOP_K_RESULTS=5

# Chunk size: how many characters per document chunk
# Smaller chunks = more precise retrieval
# Larger chunks = more context per chunk
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
